# ===================================================================
# OneUnited Bank — Environment Configuration
# Copy this file to .env and fill in your actual values
# ===================================================================

# -------------------------------------------------------------------
# Kimi OAuth (Authentication)
# These are auto-generated by the backend-building init script
# -------------------------------------------------------------------
APP_ID=your-app-id
APP_SECRET=your-app-secret
KIMI_AUTH_URL=https://your-portal.kimi.com
KIMI_OPEN_URL=https://your-portal.kimi.com
OWNER_UNION_ID=your-owner-union-id

# -------------------------------------------------------------------
# Supabase Configuration (PostgreSQL Database)
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/database
# -------------------------------------------------------------------
# Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Your Supabase anon/public key (safe for client-side)
SUPABASE_ANON_KEY=your-anon-key
# Your Supabase service role key (SERVER ONLY — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------------------
# Database Connection (Drizzle ORM)
# Use the Supabase connection string from:
# Project Settings > Database > Connection String
# -------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.your-project-ref:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# -------------------------------------------------------------------
# Client-Side Variables (prefixed with VITE_)
# These are embedded in the frontend bundle at build time
# -------------------------------------------------------------------
VITE_APP_ID=${APP_ID}
VITE_APP_SECRET=${APP_SECRET}
VITE_KIMI_AUTH_URL=${KIMI_AUTH_URL}
VITE_API_URL=/api
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# -------------------------------------------------------------------
# Optional: Node Environment
# -------------------------------------------------------------------
NODE_ENV=production
